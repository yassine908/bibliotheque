{% extends 'base.html.twig' %}
{% block title %}{{ categorie.nom }} — Bibliothèque{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h2>{{ categorie.nom }}</h2>
        <p class="sub">{{ livres|length }} ouvrage{% if livres|length != 1 %}s{% endif %} dans cette catégorie</p>
    </div>
    <a href="{{ path('app_livre_index') }}" class="btn btn-ghost">Tout le catalogue</a>
</div>

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Titre</th>
                <th>Auteur</th>
                <th>Année</th>
                <th>Disponibilité</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for livre in livres %}
                <tr>
                    <td class="title-cell">{{ livre.titre }}</td>
                    <td class="author-cell">{{ livre.auteur }}</td>
                    <td class="year-cell">{{ livre.annee }}</td>
                    <td>
                        {% if livre.disponible %}
                            <span class="badge badge-avail">Disponible</span>
                        {% else %}
                            <span class="badge badge-unavail">Emprunté</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="row-actions">
                            <a href="{{ path('app_livre_show', {'id': livre.id}) }}" class="row-btn row-btn-view">Voir</a>
                            <a href="{{ path('app_livre_edit', {'id': livre.id}) }}" class="row-btn row-btn-edit">Modifier</a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">
                        <div class="empty-state">
                            <svg width="52" height="46" viewBox="0 0 52 46" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M26 8 C23 3, 13 3, 5 7 L5 41 C13 37, 23 37, 26 42 C29 37, 39 37, 47 41 L47 7 C39 3, 29 3, 26 8Z"
                                      stroke="#1a1510" stroke-width="1.2" fill="none"/>
                                <line x1="26" y1="8" x2="26" y2="42" stroke="#1a1510" stroke-width="1"/>
                            </svg>
                            <p>Aucun ouvrage dans la catégorie <em>{{ categorie.nom }}</em>.</p>
                            <a href="{{ path('app_livre_new') }}" class="empty-link">Ajouter un livre</a>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
