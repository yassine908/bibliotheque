{% extends 'base.html.twig' %}

{% block body %}
<h2>Ajouter un nouveau livre</h2>

<form method="post" style="margin-top: 30px;">
    <div class="form-group">
        <label for="titre">Titre *</label>
        <input type="text" id="titre" name="titre" class="form-control" required>
    </div>

    <div class="form-group">
        <label for="auteur">Auteur *</label>
        <input type="text" id="auteur" name="auteur" class="form-control" required>
    </div>

    <div class="form-group">
        <label for="annee">Année de publication *</label>
        <input type="number" id="annee" name="annee" class="form-control" min="1900" max="2024" required>
    </div>

    <div class="form-group">
        <label for="categorie">Catégorie</label>
        <select id="categorie" name="categorie" class="form-control">
            <option value="">-- Aucune catégorie --</option>
            {% for cat in categories %}
                <option value="{{ cat.id }}">{{ cat.nom }}</option>
            {% endfor %}
        </select>
    </div>

    <div class="form-group">
        <label for="resume">Résumé</label>
        <textarea id="resume" name="resume" class="form-control" rows="5"></textarea>
    </div>

    <div class="form-group">
        <label>
            <input type="checkbox" name="disponible" value="1" checked>
            Disponible immédiatement
        </label>
    </div>

    <button type="submit" class="btn btn-success">Enregistrer le livre</button>
    <a href="{{ path('app_livre_index') }}" class="btn">Annuler</a>
</form>
{% endblock %}