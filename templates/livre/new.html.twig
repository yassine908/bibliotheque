{% extends 'base.html.twig' %}
{% block title %}Nouveau livre — Bibliothèque{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h2>Nouveau livre</h2>
        <p class="sub">Enregistrer un nouvel ouvrage</p>
    </div>
    <a href="{{ path('app_livre_index') }}" class="btn btn-ghost">Annuler</a>
</div>

<div class="form-card">
    <form method="post">
        <div class="form-group">
            <label class="form-label" for="titre">Titre</label>
            <input type="text" id="titre" name="titre" class="form-control"
                   placeholder="Ex : Le Comte de Monte-Cristo" required>
        </div>

        <div class="form-group">
            <label class="form-label" for="auteur">Auteur</label>
            <input type="text" id="auteur" name="auteur" class="form-control"
                   placeholder="Ex : Alexandre Dumas" required>
        </div>

        <div class="form-grid-2">
            <div class="form-group">
                <label class="form-label" for="annee">Année de publication</label>
                <input type="number" id="annee" name="annee" class="form-control"
                       placeholder="Ex : 1844" min="1000" max="2099" required>
            </div>
            <div class="form-group">
                <label class="form-label" for="categorie">Catégorie</label>
                <select id="categorie" name="categorie" class="form-control">
                    <option value="">Aucune</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id }}">{{ cat.nom }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label" for="resume">Résumé</label>
            <textarea id="resume" name="resume" class="form-control"
                      placeholder="Brève description de l'ouvrage…"></textarea>
        </div>

        <div class="form-group">
            <label class="check-row">
                <input type="checkbox" name="disponible" value="1" checked>
                <span>Disponible à l'emprunt</span>
            </label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-dark">Enregistrer</button>
            <a href="{{ path('app_livre_index') }}" class="btn btn-ghost">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}
