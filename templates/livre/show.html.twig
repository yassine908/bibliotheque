{% extends 'base.html.twig' %}
{% block title %}{{ livre.titre }} — Bibliothèque{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h2>Fiche du livre</h2>
        <p class="sub">Détail complet de l'ouvrage</p>
    </div>
    <a href="{{ path('app_livre_index') }}" class="btn btn-ghost">Retour au catalogue</a>
</div>

<div class="book-detail">
    <div class="book-hero" data-letter="{{ livre.titre|slice(0,1)|upper }}">
        <span class="hero-cat">
            {% if livre.categorie %}{{ livre.categorie.nom }}{% else %}Sans catégorie{% endif %}
        </span>
        <h3>{{ livre.titre }}</h3>
        <p class="hero-author">{{ livre.auteur }}</p>
        <div class="hero-rule"></div>
    </div>

    <div class="book-body">
        <div class="meta-strip">
            <div class="meta-cell">
                <label>Auteur</label>
                <span>{{ livre.auteur }}</span>
            </div>
            <div class="meta-cell">
                <label>Année</label>
                <span>{{ livre.annee }}</span>
            </div>
            <div class="meta-cell">
                <label>Disponibilité</label>
                <span>
                    {% if livre.disponible %}
                        <span class="badge badge-avail">Disponible</span>
                    {% else %}
                        <span class="badge badge-unavail">Emprunté</span>
                    {% endif %}
                </span>
            </div>
        </div>

        <div class="resume-block">
            {% if livre.resume %}
                <p>{{ livre.resume }}</p>
            {% else %}
                <p style="color: var(--text-muted);">Aucun résumé disponible pour cet ouvrage.</p>
            {% endif %}
        </div>

        <div class="form-actions">
            <a href="{{ path('app_livre_edit', {'id': livre.id}) }}" class="btn btn-sepia">Modifier</a>
            <a href="{{ path('app_livre_index') }}" class="btn btn-ghost">Catalogue</a>
        </div>
    </div>
</div>
{% endblock %}
